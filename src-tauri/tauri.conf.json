{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Crab Ledger",
	"version": "0.1.0",
	"identifier": "com.kavinda.crab-ledger",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Crab Ledger",
				"width": 1600,
				"height": 800,
				"minWidth": 1000,
				"minHeight": 700,
				"resizable": true,
				"decorations": true,
				"transparent": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
